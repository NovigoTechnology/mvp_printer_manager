# ==============================================================================
# Printer Fleet Manager - Environment Variables
# ==============================================================================
# Configuration centralizada usando Pydantic Settings (api/app/config.py)
# Todas las variables se validan automáticamente al iniciar la aplicación.
#
# SETUP:
# 1. Copiar este archivo a .env en desarrollo
# 2. Modificar los valores CHANGE_ME con valores seguros
# 3. En producción, usar scripts/generate_production_secrets.py para generar secretos
#
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (REQUIRED)
# ------------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# 
# ⚠️ CRITICAL: Esta variable es REQUERIDA. La aplicación no iniciará sin ella.
# ⚠️ PRODUCTION: Cambiar las credenciales por defecto postgres:postgres
#
DATABASE_URL=postgresql://postgres:postgres@db:5432/printer_fleet

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION (REQUIRED)
# ------------------------------------------------------------------------------
# Secret key para firmar tokens JWT
# 
# ⚠️ CRITICAL: Esta variable es REQUERIDA. La aplicación no iniciará sin ella.
# ⚠️ PRODUCTION: Generar un secreto aleatorio de 64 caracteres
#
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# Generar con: python scripts/generate_production_secrets.py
#
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# Algoritmo de encriptación para JWT (default: HS256)
# Opciones: HS256, HS384, HS512
JWT_ALGORITHM=HS256

# Tiempo de expiración del token JWT en minutos
# Development: 480 (8 horas)
# Production: 60-120 (1-2 horas recomendado)
#
# ⚠️ SECURITY: En producción usar un valor bajo (60-120 min)
#
JWT_EXPIRY_MINUTES=120

# ------------------------------------------------------------------------------
# CORS CONFIGURATION (CRITICAL)
# ------------------------------------------------------------------------------
# Orígenes permitidos para CORS (separados por comas, sin espacios)
# 
# Development: http://localhost:3000
# Production: https://printer-manager.imsa.local,https://10.10.10.193
#
# ⚠️ CRITICAL: NUNCA usar "*" en producción.
# ⚠️ PRODUCTION: Especificar SOLO los dominios que necesitan acceso a la API
#
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# MEDICAL PRINTERS - DRYPIX CREDENTIALS (REQUIRED for Medical Printers)
# ------------------------------------------------------------------------------
# Credenciales de acceso al modo de mantenimiento de impresoras DRYPIX
# Estas son credenciales estándar del fabricante
#
# ⚠️ REQUIRED: Necesarias para monitorear impresoras médicas DRYPIX
# ⚠️ PRODUCTION: Verificar credenciales correctas con el fabricante
#
DRYPIX_LOGIN=dryprinter
DRYPIX_PASSWORD=fujifilm

# ------------------------------------------------------------------------------
# SNMP CONFIGURATION
# ------------------------------------------------------------------------------
# Community string para SNMP v2c (usado para impresoras HP, OKI, Brother)
POLL_COMMUNITY=public

# Ruta al archivo de credenciales SNMPv3 (JSON)
# Para impresoras que requieren SNMPv3, crear archivo según:
# config/snmp_credentials.json.example
#
# ⚠️ PRODUCTION: Si usa SNMPv3, crear y configurar este archivo
#
SNMP_CONFIG_PATH=/app/config/snmp_credentials.json

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
# Límite de peticiones por defecto para todos los endpoints
# Format: "count/period" donde period puede ser: second, minute, hour, day
RATE_LIMIT_DEFAULT=1000/hour

# Límite de peticiones para endpoint de autenticación (anti-brute force)
# Recomendado: 5-10 intentos por minuto
RATE_LIMIT_AUTH=5/minute

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------------------------
# Nombre de la aplicación
APP_NAME=Printer Fleet Manager API

# Versión de la aplicación
APP_VERSION=1.0.0

# Debug mode (activa logging detallado)
# ⚠️ CRITICAL: SIEMPRE debe ser False en producción
DEBUG=False

# ------------------------------------------------------------------------------
# REDIS CONFIGURATION
# ------------------------------------------------------------------------------
# Host de Redis (en Docker Compose, usar nombre del servicio)
REDIS_HOST=redis

# Puerto de Redis
REDIS_PORT=6379

# Contraseña de Redis (opcional, None si no tiene contraseña)
# ⚠️ PRODUCTION: Configurar contraseña en Redis y establecer aquí
# REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# FRONTEND (Next.js)
# ------------------------------------------------------------------------------
# Base URL de la API para el frontend
# Development: http://localhost:8000
# Production: https://api.printer-manager.imsa.local o https://10.10.10.193:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ==============================================================================
# NOTAS DE SEGURIDAD
# ==============================================================================
# 
# ✅ ANTES DE PRODUCCIÓN:
# 1. Cambiar DATABASE_URL con credenciales seguras
# 2. Generar JWT_SECRET aleatorio (64 caracteres)
# 3. Reducir JWT_EXPIRY_MINUTES a 60-120
# 4. Especificar CORS_ORIGINS exactos (NO usar "*")
# 5. Verificar DRYPIX_LOGIN/PASSWORD con fabricante
# 6. Configurar SNMP_CONFIG_PATH si usa SNMPv3
# 7. Establecer DEBUG=False
# 8. Configurar REDIS_PASSWORD si Redis tiene autenticación
#
# 📖 Para más información, ver:
# - api/app/config.py (configuración centralizada)
# - docs/RESUMEN_IMPLEMENTACION_SEGURIDAD.md
# - docs/IMPLEMENTACION_MEJORAS_PRIORIDAD_ALTA.md
#
# ==============================================================================
